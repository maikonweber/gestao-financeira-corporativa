# Application
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/corporate_finance?schema=public"

# JWT
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Seed user
SEED_USER_NAME=Admin User
SEED_USER_EMAIL=admin@corporate-finance.com
SEED_USER_PASSWORD=Admin@123
